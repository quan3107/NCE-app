# File: .gitignore | Purpose: Exclude environment, build, and generated assets from version control.
# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# Keep npm lockfiles tracked for reproducible, auditable installs.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# === Build outputs ===
dist/
build/
coverage/
*.log
.DS_Store

# === React (frontend) ===
# If frontend is in /client or /frontend folder
client/node_modules/
client/build/
frontend/node_modules/
frontend/build/
.vscode/
.idea/
*.swp

# === Database & ORM ===
# Prisma migrations or DB dumps
prisma/migrations/
backend/src/prisma/generated/
*.sqlite
*.db
*.dump
*.sql
!backend/src/prisma/migrations/**/*.sql

# === Temporary files ===
tmp/
temp/
.cache/
.factory/
*.pid
*.seed
*.bak
*.old

# === System files ===
Thumbs.db
.DS_Store

# === Testing ===
jest-results/
cypress/videos/
cypress/screenshots/
playwright-report/
coverage/

# === Logs and local data ===
logs/
*.log
*.out
*.err

# === Project-specific exclusions ===

CODEBASE_AUDIT_*.txt

docs/*
!docs/openapi/
!docs/openapi/**
!docs/npm-security-update-path-2026-05-25.md

# === Markdown ===
*.md
!README.md
!PROGRESS.md
!docs/npm-security-update-path-2026-05-25.md
