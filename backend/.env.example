# File: .env.example | Purpose: Document backend runtime environment variables.
# Copy to .env for local development and replace placeholder values with real secrets.

NODE_ENV=development
PORT=4000

# Runtime database login. Production application processes must receive only
# DATABASE_URL; inject migration-owner credentials into short-lived jobs instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nce_app

# JWT signing keys
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Brevo email delivery
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_NAME=NCE App
BREVO_SENDER_EMAIL=noreply@example.com

# Credentialed CORS browser origins, comma-separated with no paths. Required in production.
# Local frontend dev server runs on port 3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Retention cleanup. Auth sessions are soft-deleted; notification failure
# metadata is scrubbed. Rows and object storage payloads are not hard-deleted.
CLEANUP_AUTH_SESSION_RETENTION_DAYS=30
CLEANUP_NOTIFICATION_METADATA_RETENTION_DAYS=90
CLEANUP_RETENTION_BATCH_SIZE=500
CLEANUP_RETENTION_MAX_BATCHES=20

# NCE lesson audio files. The backend serves keys like nce/book1/lesson1/dialogue.mp3
# from this root; required in production for listening and dictation playback.
NCE_ASSET_ROOT=storage/nce-assets

# AI feedback provider foundation. Disabled by default; enabling requires AI_API_KEY.
# Hosted provider calls run server-side only. Verify model availability and image
# support before enabling Writing Task 1 visual feedback.
AI_FEEDBACK_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_TIMEOUT_MS=10000
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1200
AI_HEALTH_PATH=/models
# Low-cost route for ordinary explanations and cost-sensitive drafts.
AI_LOW_COST_MODEL=gpt-5.4-nano
AI_LOW_COST_REASONING_EFFORT=medium
AI_LOW_COST_SUPPORTS_IMAGE_INPUT=false
# Premium route for high-stakes, retry, low-confidence, or image-required work.
AI_PREMIUM_MODEL=gpt-5.4-mini
AI_PREMIUM_REASONING_EFFORT=high
AI_PREMIUM_SUPPORTS_IMAGE_INPUT=true
AI_IMAGE_MAX_BYTES=20971520
AI_IMAGE_SUPPORTED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif
